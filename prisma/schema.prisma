generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER") // USER | ADMIN
  accounts      Account[]
  sessions      Session[]
  rooms         Room[]
  simulations   Simulation[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domaine métier ───────────────────────────────────────────────────────────

model Room {
  id              String           @id @default(cuid())
  userId          String
  name            String
  roomType        String           // salon, chambre, bureau, salle_a_manger
  photoUrl        String?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  furniture       Furniture[]
  recommendations Recommendation[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Furniture {
  id                String           @id @default(cuid())
  roomId            String
  type              String           // canape, lit, fauteuil, table, bureau
  dominantColor     String           // beige, bleu_nuit, vert_olive, gris, marron, blanc
  style             String           // moderne, chic, minimaliste, africain, boheme, luxe
  widthCm           Float?
  imageUrl          String?
  processedImageUrl String?
  composedImageUrl  String?
  room              Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  recommendations   Recommendation[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// ─── Règles d'association ─────────────────────────────────────────────────────

model ColorRule {
  id            String   @id @default(cuid())
  dominantColor String
  accessoryType String
  suggestions   String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([dominantColor, accessoryType])
}

model StyleRule {
  id            String   @id @default(cuid())
  style         String
  accessoryType String
  suggestions   String[]
  materials     String[]
  colorPalette  String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([style, accessoryType])
}

model BudgetTier {
  id             String   @id @default(cuid())
  level          String   @unique // bas, moyen, eleve
  minAmountFcfa  Int?
  maxAmountFcfa  Int?
  accessoryTypes String[]
  description    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Catalogue produits ───────────────────────────────────────────────────────

model AccessoryCatalog {
  id          String   @id @default(cuid())
  name        String
  type        String
  styles      String[]
  colors      String[]
  priceFcfa   Int
  budgetLevel String
  imageUrl    String?
  description String?
  available   Boolean  @default(true)
  inStock     Boolean  @default(true)
  externalUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Recommandations ──────────────────────────────────────────────────────────

model Recommendation {
  id          String    @id @default(cuid())
  roomId      String
  furnitureId String
  budgetFcfa  Int
  budgetLevel String
  style       String
  accessories Json
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  furniture   Furniture @relation(fields: [furnitureId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Simulations utilisateur ──────────────────────────────────────────────────

model Simulation {
  id          String   @id @default(cuid())
  userId      String
  title       String?
  furnitureType  String
  dominantColor  String
  style          String
  budgetFcfa     Int
  budgetLevel    String
  accessories    Json     // AccessoryRecommendation[]
  totalFcfa      Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}
